<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>com.taoxuan.cloud-brain-sync</string>

    <key>ProgramArguments</key>
    <array>
      <string>/bin/zsh</string>
      <string>/Users/taoxuan/Desktop/cloud-brain/scripts/daily_sync.sh</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/taoxuan/Desktop/cloud-brain</string>

    <key>RunAtLoad</key>
    <false/>

    <key>StartCalendarInterval</key>
    <dict>
      <key>Hour</key>
      <integer>2</integer>
      <key>Minute</key>
      <integer>0</integer>
    </dict>

    <key>StandardOutPath</key>
    <string>/Users/taoxuan/Desktop/cloud-brain/logs/launchd.stdout.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/taoxuan/Desktop/cloud-brain/logs/launchd.stderr.log</string>
  </dict>
</plist>
